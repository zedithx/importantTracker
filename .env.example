# App
APP_ENV=development
LOG_LEVEL=info
LOG_FORMAT=auto
APP_PORT=8080
REQUEST_TIMEOUT_SECONDS=20
AI_REQUEST_TIMEOUT_SECONDS=60

# Storage
# For MVP this can stay local; replace with DB later if needed.
DATA_DIR=./data

# Postgres (set this to enable persistent storage; otherwise backend uses in-memory store)
# You can use either POSTGRES_DSN or DATABASE_URL.
# Supabase example format:
# postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_DSN=postgresql://postgres.<project-ref>:your_postgres_password_here@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME_MINUTES=30

# AI Provider (OpenAI-compatible)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_DEFAULT_CHAT_ID=your_default_chat_id_here

# Auth
AUTH_JWT_SECRET=replace_with_a_random_secret_at_least_16_chars
AUTH_TOKEN_TTL_HOURS=720

# Optional security placeholder (for later encryption-at-rest)
ENCRYPTION_KEY=replace_with_32_plus_char_secret

# Desktop app
CAPTURE_SHORTCUT=CommandOrControl+Shift+S
